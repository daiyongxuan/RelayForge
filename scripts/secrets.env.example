# RelayForge secrets — DO NOT COMMIT to git.
# Copy this file to ~/.config/relayforge/secrets.env and fill in your keys.
#
# DeepSeek API key — get from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-YOUR_DEEPSEEK_API_KEY_HERE"

# GLM (ZhipuAI) API key — get from https://open.bigmodel.cn
GLM_API_KEY="YOUR_GLM_API_KEY_HERE"

# ── optional overrides ────────────────────────────────────────────────
# CODEX_HOME="${HOME}/.codex"
# SPAWNER_HOME="${HOME}/.local/bin"
# CC_SWITCH_VERSION="v3.16.2"
# CC_SWITCH_PORT="15721"
# GLM_PROXY_PORT="15722"
# DEEPSEEK_MODEL="deepseek-v4-pro"
# GLM_MODEL="glm-5.2"
# CONTEXT_WINDOW="1000000"
# COMPACT_LIMIT="600000"
